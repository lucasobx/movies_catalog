<%= form_with model: movie_director do |d| %>
  <%= d.label 'Nome' %>
  <%= d.text_field :name %>

  <%= d.label 'Nacionalidade' %>
  <%= d.text_field :nationality %>

  <%= d.label 'Data de nascimento' %>
  <%= d.text_field :birth_date %>

  <%= d.label 'Gênero favorito' %>
  <%= d.collection_select :movie_genre_id, MovieGenre.all, :id, :name %>  

  <%= d.submit 'Salvar' %>
<% end %>