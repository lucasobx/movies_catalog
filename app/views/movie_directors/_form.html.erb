<%= form_with model: movie_director do |g| %>
  <%= g.label 'Nome' %>
  <%= g.text_field :name %>

  <%= g.label 'Nacionalidade' %>
  <%= g.text_field :nationality %>

  <%= g.label 'Data de nascimento' %>
  <%= g.text_field :birth_date %>

  <%= g.label 'Gênero favorito' %>
  <%= g.collection_select :movie_genre_id, MovieGenre.all, :id, :name %>  

  <%= g.submit 'Salvar' %>
<% end %>